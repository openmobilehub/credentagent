{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/credentials/(.*).mpzpass",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.multipaz.mpzpass" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    },
    {
      "source": "/trust/(.*).vical",
      "headers": [
        { "key": "Content-Type", "value": "application/cbor" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    },
    {
      "source": "/trust/(.*).rical",
      "headers": [
        { "key": "Content-Type", "value": "application/cbor" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    }
  ]
}
